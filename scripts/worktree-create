#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "--" ]]; then
  shift
fi

if [[ $# -lt 1 || $# -gt 3 ]]; then
  printf '%s\n' "Usage: scripts/worktree-create <task-id> [base-ref] [branch]" >&2
  exit 2
fi

source_tree="$(git rev-parse --show-toplevel)"
cd "$source_tree"

if [[ -n "$(git status --porcelain)" ]]; then
  printf '%s\n' "[worktree] source checkout must be clean before creating a task worktree" >&2
  exit 1
fi

raw_task_id="$1"
task_id="$(printf '%s' "$raw_task_id" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9_-]+/-/g; s/^-+//; s/-+$//' | cut -c1-48)"
if [[ -z "$task_id" ]]; then
  printf '%s\n' "[worktree] invalid task id" >&2
  exit 2
fi

base_ref="${2:-HEAD}"
branch="${3:-apex/$task_id}"
worktree_root="${SESSION_JEU_WORKTREE_ROOT:-$(dirname "$source_tree")/worktrees/$(basename "$source_tree")}"
target="$worktree_root/$task_id"

mkdir -p "$worktree_root"
if [[ -e "$target" ]]; then
  printf '%s\n' "[worktree] target already exists: $target" >&2
  exit 1
fi

git rev-parse --verify "$base_ref^{commit}" >/dev/null
if git show-ref --verify --quiet "refs/heads/$branch"; then
  git worktree add "$target" "$branch"
else
  git worktree add -b "$branch" "$target" "$base_ref"
fi

printf '%s\n' "[worktree] created $target on $branch"
CODEX_SOURCE_TREE_PATH="$source_tree" \
CODEX_WORKTREE_PATH="$target" \
WORKTREE_ID="$task_id" \
  "$target/scripts/worktree-up"

printf '%s\n' "[worktree] ready: $target"
