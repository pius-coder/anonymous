{
  "name": "@session-jeu/game-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && node --experimental-test-module-mocks --import tsx src/__tests__/colyseus-room.transport.runner.ts",
    "test:unit": "vitest run",
    "test:transport": "node --experimental-test-module-mocks --import tsx src/__tests__/colyseus-room.transport.runner.ts"
  },
  "devDependencies": {
    "@colyseus/sdk": "^0.17.43",
    "@colyseus/testing": "^0.17.11",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.27",
    "@session-jeu/config": "workspace:*",
    "@session-jeu/db": "workspace:^",
    "@session-jeu/game-engine": "workspace:^",
    "@session-jeu/shared": "workspace:*",
    "bullmq": "^5.79.3",
    "colyseus": "^0.17",
    "ioredis": "^5.4.0"
  }
}
