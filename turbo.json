{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": ["APP_ENV", "API_URL", "GAME_WS_URL", "NODE_ENV", "CI"],
      "passThroughEnv": [
        "APP_ENV",
        "API_URL",
        "GAME_WS_URL",
        "DATABASE_URL",
        "REDIS_URL",
        "NEXT_PUBLIC_*",
        "FAPSHI_*"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["CI", "NODE_ENV"]
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["CI", "NODE_ENV"]
    },
    "test:integration": {
      "cache": false,
      "dependsOn": ["^build"],
      "passThroughEnv": [
        "WORKTREE_ID",
        "WORKTREE_OFFSET",
        "TEST_INFRA_BACKEND",
        "DATABASE_URL",
        "TEST_DATABASE_URL",
        "REDIS_URL",
        "POSTGRES_*",
        "REDIS_*",
        "PORT",
        "API_PORT",
        "API_URL",
        "GAME_SERVER_PORT",
        "GAME_PORT",
        "GAME_WS_URL",
        "WEB_PORT",
        "WORKER_PORT",
        "COMPOSE_PROJECT_NAME",
        "CI",
        "LOCAL_POSTGRES_*",
        "LOCAL_REDIS_*",
        "PGHOST",
        "PGPASSWORD",
        "INTEGRATION_TIMEOUT_MS"
      ]
    },
    "test:e2e": {
      "cache": false,
      "dependsOn": ["^build"],
      "passThroughEnv": [
        "WORKTREE_ID",
        "WORKTREE_OFFSET",
        "TEST_INFRA_BACKEND",
        "DATABASE_URL",
        "TEST_DATABASE_URL",
        "REDIS_URL",
        "POSTGRES_*",
        "REDIS_*",
        "PORT",
        "API_PORT",
        "API_URL",
        "GAME_SERVER_PORT",
        "GAME_PORT",
        "GAME_WS_URL",
        "WEB_PORT",
        "WORKER_PORT",
        "E2E_BASE_URL",
        "PLAYWRIGHT_*",
        "COMPOSE_PROJECT_NAME",
        "CI",
        "NEXT_PUBLIC_*",
        "ALLOW_INSECURE_AUTH_COOKIE"
      ]
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
