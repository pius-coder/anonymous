generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  PLAYER
  SUPPORT
  FINANCE
  ADMIN
  SUPER_ADMIN
}

enum SessionVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum GameSessionStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  WAITING_START
  LIVE
  COMPLETED
  CANCELLED
}

enum SessionRegistrationStatus {
  CREATED
  PAYMENT_PENDING
  PAID
  CHECKED_IN
  IN_ROOM
  NO_SHOW
  CANCELLED
  REFUNDED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  EXPIRED
  REFUNDED
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum LedgerType {
  ENTRY_FEE
  PRIZE
  REFUND
  BONUS
  ADJUSTMENT
}

enum RoundStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum LivePhase {
  LOBBY
  BRIEFING
  ROUND_ACTIVE
  RESOLVING
  RESULTS
  PAUSED
}

enum PlayerConnectionStatus {
  CONNECTED
  DISCONNECTED
  RECONNECTING
}

enum RoundOutcomeStatus {
  QUALIFIED
  ELIMINATED
}

enum GameResultStatus {
  WINNER
  ELIMINATED
  COMPLETED
}

enum PrizeDistributionStatus {
  PENDING
  CREDITED
  FAILED
}

enum RoundingRemainderPolicy {
  FIRST_WINNER
  PLATFORM_COMMISSION
}

enum DisputeWindowStatus {
  OPEN
  CORRECTION_REQUESTED
  RESOLVED
  CLOSED
}

enum MiniGameFamily {
  SOLO
  DUEL
  ALLIANCE
  TEAM
  SURVIVAL
  HIDDEN_ROLE
}

enum MiniGamePlayerMode {
  SOLO
  DUEL
  GROUP
  TEAM
}

// Models
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  phone          String?  @unique
  passwordHash   String
  name           String?
  avatarUrl      String?
  role           UserRole @default(PLAYER)
  isActive       Boolean  @default(true)
  sessionVersion Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  profile                PlayerProfile?
  authSessions           AuthSession[]
  passwordResetTokens    PasswordResetToken[]
  roleAssignments        RoleAssignment[]      @relation("RoleAssignments")
  grantedRoleAssignments RoleAssignment[]      @relation("RoleGrantedBy")
  registrations          SessionRegistration[]
  wallet                 Wallet?
  ledgers                LedgerEntry[]
  auditLogs              AuditLog[]
  gameResults            GameResult[]
  prizeDistributions     PrizeDistribution[]
  joinTokens             JoinToken[]
  liveReservations       LiveReservation[]
  playerConnections      PlayerConnection[]
  playerActions          PlayerAction[]
  miniGameDefinitions    MiniGameDefinition[]
  disputeRequests        DisputeWindow[]       @relation("DisputeRequestedBy")
  statsSnapshot          PlayerStatsSnapshot?

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model PlayerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  username    String   @unique
  bio         String?
  avatarUrl   String?
  preferences Json?
  isPublic    Boolean  @default(false)
  level       Int      @default(1)
  xp          Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PlayerStatsSnapshot {
  id             String   @id @default(cuid())
  userId         String   @unique
  sessionsPlayed Int      @default(0)
  sessionsWon    Int      @default(0)
  winRate        Float    @default(0)
  avgFinalRank   Float?
  creditsWonXaf  Int      @default(0)
  computedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionsWon])
  @@index([computedAt])
}

model AuthSession {
  id             String    @id @default(cuid())
  userId         String
  tokenHash      String    @unique
  sessionVersion Int
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  revokedAt      DateTime?
  lastSeenAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model RoleAssignment {
  id          String    @id @default(cuid())
  userId      String
  role        UserRole
  grantedById String?
  reason      String?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  user      User  @relation("RoleAssignments", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("RoleGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@index([userId, role])
  @@index([grantedById])
  @@index([revokedAt])
}

model GameSession {
  id                   String            @id @default(cuid())
  code                 String            @unique
  name                 String
  description          String?
  status               GameSessionStatus @default(DRAFT)
  minPlayers           Int               @default(2)
  maxPlayers           Int               @default(10)
  entryFee             Float             @default(0)
  entryFeeXaf          Int               @default(0)
  visibility           SessionVisibility @default(PUBLIC)
  prizePool            Float             @default(0)
  prizePoolBps         Int               @default(6000)
  winnerSplitBps       Json
  providerFeeBps       Int               @default(300)
  configVersion        Int               @default(1)
  startTime            DateTime?
  endTime              DateTime?
  registrationClosesAt DateTime?
  publishedAt          DateTime?
  cancelledAt          DateTime?
  cancellationReason   String?
  createdBy            String
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  registrations      SessionRegistration[]
  rounds             RoundInstance[]
  gameResults        GameResult[]
  prizeDistributions PrizeDistribution[]
  shareLinks         ShareLink[]
  joinTokens         JoinToken[]
  liveState          LiveSessionState?
  liveReservations   LiveReservation[]
  playerConnections  PlayerConnection[]
  playerActions      PlayerAction[]
  roundDeadlines     RoundDeadline[]
  resolutionLogs     ResolutionLog[]
  roundOutcomes      RoundOutcome[]
  gameEvents         GameEvent[]
  commissionRecord   CommissionRecord?
  disputeWindow      DisputeWindow?

  @@index([code])
  @@index([status])
  @@index([createdBy])
  @@index([configVersion])
}

model SessionRegistration {
  id                 String                    @id @default(cuid())
  userId             String
  sessionId          String
  status             SessionRegistrationStatus @default(CREATED)
  paymentDeadlineAt  DateTime?
  paidAt             DateTime?
  checkedInAt        DateTime?
  inRoomAt           DateTime?
  noShowAt           DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  session          GameSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  payment          PaymentTransaction?
  joinTokens       JoinToken[]
  liveReservations LiveReservation[]

  @@index([userId])
  @@index([sessionId])
  @@index([sessionId, status])
  @@index([status, paymentDeadlineAt])
  @@index([status, checkedInAt])
}

model JoinToken {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  userId         String
  sessionId      String
  registrationId String
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime  @default(now())

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  session      GameSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  registration SessionRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([registrationId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model LiveSessionState {
  id             String     @id @default(cuid())
  sessionId      String     @unique
  roomId         String?
  phase          LivePhase  @default(LOBBY)
  previousPhase  LivePhase?
  currentRoundId String?
  phaseStartedAt DateTime?
  pausedAt       DateTime?
  pauseReason    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  session      GameSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  currentRound RoundInstance? @relation(fields: [currentRoundId], references: [id], onDelete: SetNull)

  @@index([phase])
  @@index([roomId])
  @@index([currentRoundId])
}

model LiveReservation {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  userId         String
  sessionId      String
  registrationId String
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime  @default(now())

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  session      GameSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  registration SessionRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([registrationId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model PlayerConnection {
  id                String                 @id @default(cuid())
  sessionId         String
  userId            String
  registrationId    String?
  roomId            String?
  colyseusSessionId String?
  status            PlayerConnectionStatus @default(CONNECTED)
  connectedAt       DateTime?
  disconnectedAt    DateTime?
  reconnectUntil    DateTime?
  lastSeenAt        DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId, status])
  @@index([userId])
  @@index([roomId])
  @@index([colyseusSessionId])
  @@index([reconnectUntil])
}

model PaymentTransaction {
  id                 String        @id @default(cuid())
  userId             String
  sessionId          String?
  registrationId     String?       @unique
  amount             Float
  amountXaf          Int
  currency           String        @default("XAF")
  status             PaymentStatus @default(PENDING)
  provider           String?
  providerExternalId String?       @unique
  providerTransId    String?       @unique
  providerStatus     String?
  checkoutUrl        String?
  reference          String?
  webhookReceivedAt  DateTime?
  metadata           Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  registration  SessionRegistration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  ledger        LedgerEntry[]
  webhookEvents WebhookEvent[]

  @@index([userId])
  @@index([sessionId])
  @@index([registrationId])
  @@index([provider, status])
  @@index([reference])
}

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  eventKey    String    @unique
  paymentId   String?
  transId     String?
  status      String?
  payload     Json
  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  payment PaymentTransaction? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([provider])
  @@index([paymentId])
  @@index([transId])
  @@index([receivedAt])
}

model Wallet {
  id         String   @id @default(cuid())
  userId     String   @unique
  balanceXaf Int      @default(0)
  currency   String   @default("XAF")
  isFrozen   Boolean  @default(false)
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgers LedgerEntry[]

  @@index([userId])
}

model LedgerEntry {
  id              String          @id @default(cuid())
  walletId        String
  userId          String
  amountXaf       Int
  balanceAfterXaf Int
  direction       LedgerDirection
  type            LedgerType
  description     String?
  referenceType   String?
  referenceId     String?
  idempotencyKey  String          @unique
  paymentId       String?
  sessionId       String?
  createdAt       DateTime        @default(now())

  wallet  Wallet              @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment PaymentTransaction? @relation(fields: [paymentId], references: [id])

  @@index([walletId])
  @@index([userId])
  @@index([paymentId])
  @@index([sessionId])
  @@index([referenceType, referenceId])
  @@index([createdAt])
}

model RoundInstance {
  id                   String      @id @default(cuid())
  sessionId            String
  miniGameDefinitionId String?
  configJson           Json?
  roundNum             Int
  status               RoundStatus @default(PENDING)
  startTime            DateTime?
  endTime              DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  session            GameSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  results            RoundResult[]
  liveState          LiveSessionState[]
  deadline           RoundDeadline?
  playerActions      PlayerAction[]
  resolutionLog      ResolutionLog?
  outcomes           RoundOutcome[]
  gameEvents         GameEvent[]
  miniGameDefinition MiniGameDefinition? @relation(fields: [miniGameDefinitionId], references: [id], onDelete: SetNull)

  @@unique([sessionId, roundNum])
  @@index([sessionId])
  @@index([miniGameDefinitionId])
}

model MiniGameDefinition {
  id                String             @id @default(cuid())
  key               String
  name              String
  description       String
  family            MiniGameFamily
  playerMode        MiniGamePlayerMode
  resolverId        String
  enabled           Boolean            @default(true)
  version           Int
  configSchema      Json
  defaultConfig     Json
  allowedActions    Json
  antiCheatPolicy   Json
  clientStateSchema Json
  uiCopy            Json
  createdBy         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  rounds  RoundInstance[]
  creator User?           @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([key, version])
  @@index([key])
  @@index([family])
  @@index([enabled])
  @@index([createdBy])
}

model RoundDeadline {
  id         String    @id @default(cuid())
  sessionId  String
  roundId    String    @unique
  deadlineAt DateTime
  closedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  session GameSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  round   RoundInstance @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([deadlineAt])
  @@index([closedAt])
}

model PlayerAction {
  id              String    @id @default(cuid())
  sessionId       String
  roundId         String
  userId          String
  actionNonce     String
  actionType      String
  payload         Json
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())

  session GameSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  round   RoundInstance @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roundId, userId, actionNonce])
  @@index([sessionId])
  @@index([roundId])
  @@index([userId])
  @@index([acceptedAt])
  @@index([rejectedAt])
}

model RoundResult {
  id       String @id @default(cuid())
  roundId  String
  playerId String
  score    Int    @default(0)
  rank     Int?
  metadata Json?

  round RoundInstance @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([roundId, playerId])
  @@index([roundId])
  @@index([playerId])
}

model RoundOutcome {
  id        String             @id @default(cuid())
  roundId   String
  sessionId String
  userId    String
  status    RoundOutcomeStatus
  reason    String?
  createdAt DateTime           @default(now())

  round   RoundInstance @relation(fields: [roundId], references: [id], onDelete: Cascade)
  session GameSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([roundId, userId])
  @@index([sessionId])
  @@index([userId])
  @@index([status])
}

model ResolutionLog {
  id             String    @id @default(cuid())
  roundId        String    @unique
  sessionId      String
  resolverId     String
  inputHash      String
  outputHash     String
  inputSnapshot  Json
  outputSnapshot Json
  evidence       Json
  seedLog        Json
  createdAt      DateTime  @default(now())
  replayedAt     DateTime?

  round   RoundInstance @relation(fields: [roundId], references: [id], onDelete: Cascade)
  session GameSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([resolverId])
  @@index([inputHash])
  @@index([outputHash])
  @@index([createdAt])
}

model GameEvent {
  id            String    @id @default(cuid())
  sessionId     String?
  roundId       String?
  eventType     String
  aggregateType String
  aggregateId   String
  payload       Json
  createdAt     DateTime  @default(now())
  processedAt   DateTime?

  session GameSession?   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  round   RoundInstance? @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([roundId])
  @@index([eventType])
  @@index([aggregateType, aggregateId])
  @@index([processedAt])
  @@index([createdAt])
}

model GameResult {
  id             String           @id @default(cuid())
  sessionId      String
  userId         String
  finalRank      Int?
  totalScore     Int              @default(0)
  finalStatus    GameResultStatus @default(COMPLETED)
  prizeWon       Float            @default(0)
  prizeWonXaf    Int              @default(0)
  idempotencyKey String           @unique
  finalizedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@index([finalStatus])
  @@index([finalizedAt])
}

model PrizeDistribution {
  id             String                  @id @default(cuid())
  sessionId      String
  userId         String
  amount         Float
  amountXaf      Int
  rank           Int
  status         PrizeDistributionStatus @default(PENDING)
  idempotencyKey String                  @unique
  paidAt         DateTime?
  creditedAt     DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@index([status])
  @@index([creditedAt])
}

model CommissionRecord {
  id                        String                  @id @default(cuid())
  sessionId                 String                  @unique
  grossCollectionXaf        Int
  providerFeesXaf           Int
  netCollectionXaf          Int
  prizePoolXaf              Int
  organizationCommissionXaf Int
  roundingRemainderXaf      Int                     @default(0)
  roundingRemainderPolicy   RoundingRemainderPolicy @default(FIRST_WINNER)
  idempotencyKey            String                  @unique
  createdAt                 DateTime                @default(now())

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model DisputeWindow {
  id            String              @id @default(cuid())
  sessionId     String              @unique
  status        DisputeWindowStatus @default(OPEN)
  opensAt       DateTime
  closesAt      DateTime
  requestedById String?
  requestReason String?
  requestedAt   DateTime?
  resolvedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  requestedBy User?       @relation("DisputeRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([closesAt])
  @@index([requestedById])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  reason    String?
  requestId String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([requestId])
  @@index([createdAt])
}

model ShareLink {
  id         String    @id @default(cuid())
  token      String    @unique
  sessionId  String
  createdBy  String?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  clickCount Int       @default(0)

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([sessionId])
}
