# ─── Worktree isolation (SEQ-00) ─────────────────────────────────────────────
# Stable id for disposable DB/Redis and unique ports. Defaults to sanitized cwd name.
# WORKTREE_ID=my-task
# Optional fixed offset 0-199 (otherwise derived from WORKTREE_ID hash).
# WORKTREE_OFFSET=12
# docker | local  (default: docker if available, else local host PG/Redis)
# TEST_INFRA_BACKEND=docker

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/session_jeu?schema=public
# Integration suites prefer TEST_DATABASE_URL when set.
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:15432/session_jeu_wt_default?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379/0
# REDIS_DB=0

# PostgreSQL (docker-compose / infra scripts)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=session_jeu
# Host-mapped ports when using docker test infra (auto-derived from WORKTREE_ID if unset)
# POSTGRES_PORT=5432

# ─── App ports (auto-derived from WORKTREE_ID when using test scripts) ───────
NODE_ENV=development
PORT=3001
API_PORT=3001
API_URL=http://localhost:3001
# Game server (code reads GAME_SERVER_PORT; GAME_PORT kept as alias for scripts)
GAME_SERVER_PORT=3002
GAME_PORT=3002
GAME_WS_URL=ws://localhost:3002
WEB_PORT=3000
WORKER_PORT=3003
E2E_BASE_URL=http://localhost:3000

# Fapshi sandbox
FAPSHI_ENV=sandbox
FAPSHI_BASE_URL=https://sandbox.fapshi.com
FAPSHI_API_USER=your_sandbox_api_user_here
FAPSHI_API_KEY=your_sandbox_api_key_here
FAPSHI_WEBHOOK_SECRET=your_webhook_secret_here

# Web dev LAN access
# Use one of these when testing on a phone at http://<ip>:3000.
# Next expects hostnames here, so both "10.249.227.99" and
# "http://10.249.227.99:3000" are accepted by apps/web/next.config.ts.
LAN_IP=10.249.227.99
NEXT_DEV_ALLOWED_HOST=10.249.227.99
NEXT_ALLOWED_DEV_ORIGINS=10.249.227.99

# Colyseus endpoint returned by the API reservation route for browser clients.
# GAME_WS_URL is set above; override for LAN:
# GAME_WS_URL=ws://10.249.227.99:3002

# Local-only: allow insecure session cookies on HTTP LAN
# ALLOW_INSECURE_AUTH_COOKIE=true
