# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/session_jeu?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=session_jeu

# Fapshi sandbox
FAPSHI_ENV=sandbox
FAPSHI_BASE_URL=https://sandbox.fapshi.com
FAPSHI_API_USER=your_sandbox_api_user_here
FAPSHI_API_KEY=your_sandbox_api_key_here
FAPSHI_WEBHOOK_SECRET=your_webhook_secret_here

# App
NODE_ENV=development
PORT=3001
GAME_PORT=2567
API_URL=http://localhost:3001

# Web dev LAN access
# Use one of these when testing on a phone at http://<ip>:3000.
# Next expects hostnames here, so both "10.249.227.99" and
# "http://10.249.227.99:3000" are accepted by apps/web/next.config.ts.
LAN_IP=10.249.227.99
NEXT_DEV_ALLOWED_HOST=10.249.227.99
NEXT_ALLOWED_DEV_ORIGINS=10.249.227.99

# Colyseus endpoint returned by the API reservation route for browser clients.
GAME_WS_URL=ws://10.249.227.99:2567
