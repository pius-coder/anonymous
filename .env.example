# ─── Deployment environment (P-SEQ-00) ───────────────────────────────────────
# local | test | staging | production
# Strict envs (staging/production) fail-fast if required vars are missing or
# point at localhost / fake providers / seed credentials.
APP_ENV=local

# ─── Worktree isolation ──────────────────────────────────────────────────────
# Stable id for disposable DB/Redis and unique ports. Defaults to sanitized cwd name.
# WORKTREE_ID=my-task
# Optional fixed offset 0-199 (otherwise derived from WORKTREE_ID hash).
# WORKTREE_OFFSET=12
# docker | local  (default: docker if available, else local host PG/Redis)
# TEST_INFRA_BACKEND=docker

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/session_jeu?schema=public
# Integration suites prefer TEST_DATABASE_URL when set.
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:15432/session_jeu_wt_default?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379/0
# REDIS_DB=0

# PostgreSQL (docker-compose / infra scripts)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=session_jeu
# Host-mapped ports when using docker test infra (auto-derived from WORKTREE_ID if unset)
# POSTGRES_PORT=5432

# ─── App ports (auto-derived from WORKTREE_ID when using test scripts) ───────
NODE_ENV=development
PORT=3001
API_PORT=3001
API_URL=http://localhost:3001
# Game server (code reads GAME_SERVER_PORT; GAME_PORT kept as alias for scripts)
GAME_SERVER_PORT=3002
GAME_PORT=3002
GAME_WS_URL=ws://localhost:3002
WEB_PORT=3000
WORKER_PORT=3003
E2E_BASE_URL=http://localhost:3000

# ─── Fapshi collection (never put real secrets in this file) ─────────────────
# Required when APP_ENV=staging|production. Fail-closed: no fapshi-local / fake checkout.
# Official bases only: https://sandbox.fapshi.com | https://live.fapshi.com
# Headers used server-side: apiuser + apikey (never Bearer, never browser).
FAPSHI_ENV=sandbox
FAPSHI_BASE_URL=https://sandbox.fapshi.com
FAPSHI_API_USER=
FAPSHI_API_KEY=
FAPSHI_WEBHOOK_SECRET=
# Kill switch: set 0/false to refuse new collection initiates
FAPSHI_COLLECTION_ENABLED=1
# Public app origin for server-built Fapshi redirectUrl after checkout
# APP_PUBLIC_URL=http://localhost:3000
# Opt-in L4 sandbox network contract tests
# FAPSHI_RUN_SANDBOX=1

# Web dev LAN access
# Use one of these when testing on a phone at http://<ip>:3000.
# Next expects hostnames here, so both "10.249.227.99" and
# "http://10.249.227.99:3000" are accepted by apps/web/next.config.ts.
# LAN_IP=
# NEXT_DEV_ALLOWED_HOST=
# NEXT_ALLOWED_DEV_ORIGINS=

# Colyseus endpoint returned by the API reservation route for browser clients.
# GAME_WS_URL is set above; override for LAN:
# GAME_WS_URL=ws://10.249.227.99:3002

# Local-only: allow insecure session cookies on HTTP LAN
# ALLOW_INSECURE_AUTH_COOKIE=true

# ─── Seed safety ─────────────────────────────────────────────────────────────
# Never set in staging/production. Seed uses fixed demo credentials for local/test only.
# ALLOW_SEED_IN_PRODUCTION=0

# ─── Test levels ─────────────────────────────────────────────────────────────
# L1 unit: pnpm test:unit (strips DATABASE_URL/REDIS_URL)
# L3/L4:   pnpm test:integration (Postgres+Redis+API+Colyseus+worker)
# L5:      pnpm test:e2e (Playwright workers parallel; seed-lock)
# INTEGRATION_WITH_WORKER=1
# PLAYWRIGHT_WORKERS=2
